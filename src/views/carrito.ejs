<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Carrito - HardZone</title>
</head>
<body>
    <%- include('./partials/header') %>

    <main>
        <h1>Tu Carrito de Compras</h1>
        <p>Revisá y modificá tu pedido antes de finalizar la compra.</p>

        <div style="border: 1px solid #ccc; padding: 15px; margin-bottom: 15px; max-width: 400px;">
            <h3>Auriculares HyperX Cloud 2</h3>
            <p>Precio Unitario: $100</p>
            <p>
                Cantidad: 
                <button type="button">-</button> 
                <span>1</span> 
                <button type="button">+</button>
            </p>
            <button type="button" style="color: red;">Eliminar del carrito</button>
        </div>

        <button type="button">Confirmar Compra</button>
    </main>
</body>
</html>
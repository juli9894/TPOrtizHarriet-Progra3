<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Registro - Panel Administrativo</title>
</head>
<body>
    <%- include('./partials/header', { mostrarNav: false }) %>
    <main class="container" style="max-width: 500px;">
        <h1>Crear Cuenta de Administrador</h1>
        
        <form action="/registro" method="POST" class="form">
            <div class="campo-form campo-completo">
                <label for="nombre">Nombre Completo:</label>
                <input type="text" id="nombre" name="nombre" required>
            </div>

            <div class="campo-form campo-completo">
                <label for="email">Correo:</label>
                <input type="email" id="email" name="email" required>
            </div>

            <div class="campo-form campo-completo">
                <label for="password">Contraseña:</label>
                <input type="password" id="password" name="password" required>
            </div>

            <div class="campo-form campo-completo">
                <button type="submit" style="background-color: #28a745;">Registrarse</button>
                <% if (mensaje) { %>
                    <label  style="text-align: center; color: red;"><%= mensaje %></label>
                <% } %>
            </div>
        </form>

        <p style="text-align: center; margin-top: 20px;">
            ¿Ya tenes cuenta? <a href="/login" style="color: #007bff; text-decoration: none; font-weight: bold;">Ingresa aca</a>
        </p>
    </main>
    <%- include('./partials/footer') %>
</body>
</html>
<script>
    const favicon = document.createElement('link');
    favicon.rel = 'icon';
    favicon.href = 'https://fav.farm/💻';
    document.head.appendChild(favicon);

    if (localStorage.getItem('temaHardzone') === 'oscuro') {
        document.documentElement.classList.add('dark-theme');
    }

    function cambiarInvitado() {
        let confirmacion = confirm("¿Querés salir y cambiar de usuario? Esto vaciará tu carrito de compras actual.");
        
        if (confirmacion){
            localStorage.removeItem("nombreInvitado");
            localStorage.removeItem("carritoHardzone");
            window.location.href = "/logout";
        }
    }
</script>

<script src="/js/carrito.js"></script>

<header>
    <div class="barra" id="primeraBarra">
        <p>Los mejores precios en todo el país</p>
    </div>
    
    <div class="barra" id="segundaBarra">

        <a href="#" onclick="cambiarInvitado()">
            <h2 class="logo">💻 HardZone Autoservicio</h2>
        </a>

        <nav>
            <button type="button" onclick="alternarTema()" id="btn-toggle-tema" class="nav-btn" style="background: #1f1f1f; color: #fff; border: none; cursor: pointer; padding: 0 12px; font-size: 1.1rem;" title="Cambiar tema">🌙</button>

            <%# Acceso rapido al dashboard %>
            <% if(login) { %>
                <a href="/login?test=1" class="nav-btn" style="background: #aaa;">🛡️</a>
            <% } %>

            <% if(categorias) { %>
                <a href="/categorias" class="nav-btn" style="background: #3186d1;">Atras</a>
            <% } %>

            <% if(carrito) { %>
                <a href="/carrito" class="nav-btn" style="background: #28a745;">Finalizar</a>
            <% } %>

            <% if(ventas) { %>
                <a href="/admin/ventas" class="nav-btn" style="background: #aaa;">Ventas</a>
            <% } %>

            <% if(dashboard) { %>
                <a href="/admin/dashboard" class="nav-btn" style="background: #aaa;">Panel</a>
            <% } %>

            <% if(logout) { %>
                <a href="/logout" class="nav-btn" style="background: #e23e3e;">Cerrar sesión</a>
            <% } %>
        </nav>
    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const botonTema = document.getElementById('btn-toggle-tema');
        if (localStorage.getItem('temaHardzone') === 'oscuro') {
            document.documentElement.classList.add('dark-theme');
            document.body.classList.add('dark-theme');
            if (botonTema) botonTema.innerText = '☀️';
        }
    });

    function alternarTema() {
        const botonTema = document.getElementById('btn-toggle-tema');
        document.documentElement.classList.toggle('dark-theme');
        document.body.classList.toggle('dark-theme');

        if (document.body.classList.contains('dark-theme')) {
            localStorage.setItem('temaHardzone', 'oscuro');
            if (botonTema) botonTema.innerText = '☀️';
        } else {
            localStorage.setItem('temaHardzone', 'claro');
            if (botonTema) botonTema.innerText = '🌙';
        }
    }
</script>
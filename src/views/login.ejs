<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingresar - Panel Administrativo</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    
    <main class="admin-container" style="max-width: 500px;">
        <h1>Iniciar Sesión</h1>
        
        <form action="/login" method="POST" class="formulario-admin">

            <div class="campo-form campo-completo">
                <label for="email">Correo:</label>
                <input type="email" id="email" name="email" required>
            </div>

            <div class="campo-form campo-completo">
                <label for="password">Contraseña:</label>
                <input type="password" id="password" name="password" required>
            </div>

            <button type="submit" style="background-color: #007bff;">Ingresar</button>

        </form>

        <p style="text-align: center; margin-top: 20px;">
            ¿No tenés cuenta? <a href="/registro" style="color: #007bff; text-decoration: none; font-weight: bold;">Registrate</a>
        </p>
    </main>

</body>
</html>
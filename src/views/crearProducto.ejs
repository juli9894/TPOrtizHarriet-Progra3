<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administracion - Crear Producto</title>
    <link rel="stylesheet" href="/css/admin.css">
    </head>
<body>
    
    <main class="admin-container">
        <h1>Agregar Nuevo Producto</h1>
        
        <form action="/admin/crear" method="POST" class="formulario-admin">
            
            <div class="campo-form">
                <label for="nombre">Nombre del Producto:</label>
                <input type="text" id="nombre" name="nombre" required>
            </div>

            <div class="campo-form">
                <label for="precio">Precio:</label>
                <input type="number" id="precio" name="precio" required>
            </div>

            <div class="campo-form campo-completo">
                <label for="descripcion">Descripción del Producto:</label>
                <textarea id="descripcion" name="descripcion" rows="4" placeholder="Escribí los detalles técnicos aquí..."></textarea>
            </div>
            
            <button type="submit">Guardar Producto</button>

        </form>
    </main>

</body>
</html>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Administración - Editar Producto</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include("./partials/header", { mostrarNav: true }) %>
    <main class="container">
        <h1>Modificar Producto: <%= producto.nombre %></h1>
        
        <form action="/admin/editar/<%= producto.id %>" method="POST" class="form" enctype="multipart/form-data">
            
            <div class="campo-form">
                <label for="nombre">Nombre del Producto:</label>
                <input type="text" id="nombre" name="nombre" value="<%= producto.nombre %>" required>
            </div>

            <div class="campo-form">
                <label for="precio">Precio ($):</label>
                <input type="number" id="precio" name="precio" value="<%= producto.precio %>" required>
            </div>

            <div class="campo-form campo-completo">
                <label for="descripcion">Descripción del Producto:</label>
                <textarea id="descripcion" name="descripcion" rows="4"><%= producto.descripcion %></textarea>
            </div>

            <div class="campo-form campo-completo">
                <label>Imagen Actual:</label>
                <img src="/img/productos/<%= producto.imagen %>" alt="Imagen actual" style="width: 150px; border-radius: 5px; margin-bottom: 10px;">
                
                <label for="imagen">Reemplazar Imagen (Dejar vacio para conservar la actual):</label>
                <input type="file" id="imagen" name="imagen" accept="image/*">
            </div>

            <button type="submit" style="background-color: #ffc107; color: #212529;">Guardar Cambios</button>

        </form>
    </main>
    <%- include("./partials/footer") %>
</body>
</html>